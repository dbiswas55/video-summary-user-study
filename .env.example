# Copy this file to .env and edit values for the target environment.
# Do not commit .env.

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=userstudy_vds
DB_USER=root
DB_PASS=
DB_SOCKET=

# App URL settings
# Local MAMP:
# BASE_URL=/userstudy2/
# APP_URL=http://localhost:8888/userstudy2/
#
# AWS/Windows subfolder target:
# BASE_URL=/public/sites/userstudy2/
# APP_URL=https://www.videopoints.org/public/sites/userstudy2/
BASE_URL=/userstudy2/
APP_URL=http://localhost:8888/userstudy2/

DEBUG=true
SESSION_LIFETIME=3600

# Optional resource/video overrides.
# Leave empty when resources are served from BASE_URL/resources.
RESOURCES_URL=
VIDEO_ROOT_URL=

# Optional email settings.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=thevideopoints@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM_EMAIL=thevideopoints@gmail.com
MAIL_FROM_NAME=VideoPoints User Study
ADMIN_NOTIFY_EMAIL=thevideopoints@gmail.com
